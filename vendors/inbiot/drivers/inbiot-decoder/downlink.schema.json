{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "bytes": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0, "maximum": 255 }
    },
    "fPort": { "type": "integer", "minimum": 1, "maximum": 223 },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["bytes", "fPort", "errors", "warnings"],
  "additionalProperties": false
}

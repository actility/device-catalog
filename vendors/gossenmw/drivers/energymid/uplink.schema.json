{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Uplink decoded data schema",
  "type": "object",

  "properties": {
    "data": {
      "type": "object",
      "properties": {

        "timestamp": {
          "type": "object",
          "description": "Decoded timestamp structure",
          "properties": {
            "second": { "type": "integer", "minimum": 0, "maximum": 59 },
            "minute": { "type": "integer", "minimum": 0, "maximum": 59 },
            "hour":   { "type": "integer", "minimum": 0, "maximum": 23 },
            "day":    { "type": "integer", "minimum": 1, "maximum": 31 },
            "month":  { "type": "integer", "minimum": 1, "maximum": 12 },
            "year":   { "type": "integer", "minimum": 0, "maximum": 9999 },
            "timestamp_iso": { "type": "string" }
          },
          "required": ["second", "minute", "hour", "day", "month", "year", "timestamp_iso"]
        },

        "import_active_energy": {
          "type": "number",
          "description": "Import active energy in kWh (decoded IEEE754 double / 1000)"
        },

        "export_active_energy": {
          "type": "number",
          "description": "Export active energy in kWh (decoded IEEE754 double / 1000)"
        },

        "error_status": {
          "type": "object",
          "description": "Bit‑mapped device error flags",
          "properties": {
            "phase_voltage_too_low":            { "type": "boolean" },
            "phase_voltage_too_high":           { "type": "boolean" },
            "phase_current_exceeded":           { "type": "boolean" },
            "frequency_synchronization_error":  { "type": "boolean" },
            "reset_performed":                  { "type": "boolean" },
            "internal_communication_problem":   { "type": "boolean" },
            "dc_offset_too_high":               { "type": "boolean" }
          }
        }

      },
      "additionalProperties": false
    },

    "errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },

  "additionalProperties": false
}
